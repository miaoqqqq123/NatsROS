<dx:ThemedWindow
    x:Class="NatsROS.Dashboard.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    Title="NatsROS 动态节点管理器 (DevExpress Edition)"
    Width="1100"
    Height="700"
    Closing="Window_Closing"
    Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  顶部：节点加载控制台  -->
        <dxlc:LayoutControl Grid.Row="0" Margin="5">
            <dxlc:LayoutGroup
                Header="动态装载节点"
                Orientation="Horizontal"
                View="GroupBox">
                <dxlc:LayoutItem Label="程序集(DLL):">
                    <dxe:TextEdit x:Name="TxtAssembly" Text="NatsROS.Examples" />
                </dxlc:LayoutItem>
                <dxlc:LayoutItem Label="类名(Class):">
                    <dxe:TextEdit x:Name="TxtType" Text="NatsROS.Examples.DynamicTalkerNode" />
                </dxlc:LayoutItem>
                <dxlc:LayoutItem Label="节点名(Name):">
                    <dxe:TextEdit x:Name="TxtNodeName" Text="sensor_1" />
                </dxlc:LayoutItem>
                <dx:SimpleButton
                    Width="130"
                    Margin="10,0,0,0"
                    Click="BtnLoadNode_Click"
                    Content="🚀 注入母体 (Load)"
                     />
                <dx:SimpleButton
                    Width="100"
                    Margin="5,0,0,0"
                    Click="BtnRefresh_Click"
                    Content="🔄 刷新列表"
                     />
            </dxlc:LayoutGroup>
        </dxlc:LayoutControl>

        <!--  下方主体：左右分栏  -->
        <Grid Grid.Row="1" Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  左侧：母体节点列表 (使用 DX GridControl)  -->
            <dxlc:LayoutGroup
                Grid.Column="0"
                Header="正在运行的节点 (Container)"
                View="GroupBox">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <dxg:GridControl
                        x:Name="GridNodes"
                        AutoGenerateColumns="None"
                        EnableSmartColumnsGeneration="False">
                        <dxg:GridControl.View>
                            <dxg:TableView
                                AllowEditing="False"
                                NavigationStyle="Row"
                                ShowGroupPanel="False" />
                        </dxg:GridControl.View>
                        <dxg:GridColumn
                            Width="*"
                            FieldName="NodeName"
                            Header="节点名称 (Node Name)" />
                    </dxg:GridControl>

                    <dx:SimpleButton
                        Grid.Row="1"
                        Height="30"
                        Margin="0,10,0,0"
                        Click="BtnUnloadNode_Click"
                        Content="⏹️ 卸载选中节点 (Unload)" />
                </Grid>
            </dxlc:LayoutGroup>

            <!--  分隔条  -->
            <GridSplitter
                Grid.Column="1"
                Width="5"
                HorizontalAlignment="Center"
                Background="Transparent" />

            <!--  右侧：全局日志看板 (使用原生 RichTextBox 支持多颜色追加)  -->
            <dxlc:LayoutGroup
                Grid.Column="2"
                Header="全局遥测日志 (/rosout)"
                View="GroupBox">
                <RichTextBox
                    x:Name="RtbLogs"
                    Background="#1E1E1E"
                    FontFamily="Consolas"
                    FontSize="13"
                    Foreground="White"
                    IsReadOnly="True"
                    VerticalScrollBarVisibility="Auto">
                    <FlowDocument x:Name="LogDocument" PagePadding="5" />
                </RichTextBox>
            </dxlc:LayoutGroup>
        </Grid>
    </Grid>
</dx:ThemedWindow>
