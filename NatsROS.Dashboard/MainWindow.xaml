<dx:ThemedWindow
    x:Class="NatsROS.Dashboard.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
    xmlns:dxd="http://schemas.devexpress.com/winfx/2008/xaml/docking"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
    xmlns:dxr="http://schemas.devexpress.com/winfx/2008/xaml/ribbon"
    Title="NatsROS 工业控制大屏 (Dashboard 2.0)"
    Width="1200"
    Height="800"
    Closing="Window_Closing"
    Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  1. 顶部：Ribbon 菜单  -->
        <dxr:RibbonControl
            x:Name="MainRibbon"
            Grid.Row="0"
            RibbonStyle="Office2019"
            ShowApplicationButton="False">
            <dxr:RibbonDefaultPageCategory x:Name="RibbonCategory">

                <!--  【新增】：固定内置的“核心控制”选项卡  -->
                <dxr:RibbonPage Caption="系统核心 (System Core)">
                    <dxr:RibbonPageGroup Caption="视图控制 (View Control)">
                        <!--  清空日志按钮  -->
                        <dxb:BarButtonItem
                            x:Name="BtnClearLog"
                            Content="清空日志视图"
                            ItemClick="BtnClearLog_ItemClick"
                            LargeGlyph="{dx:DXImage 'SvgImages/Icon Builder/Actions_Clear.svg'}"
                            RibbonStyle="Large" />
                        <!--  快速恢复默认布局  -->
                        <dxb:BarButtonItem
                            x:Name="BtnRestoreLayout"
                            Content="恢复默认布局"
                            ItemClick="BtnRestoreLayout_ItemClick"
                            LargeGlyph="{dx:DXImage 'SvgImages/Dashboards/Layout.svg'}"
                            RibbonStyle="Large" />
                    </dxr:RibbonPageGroup>

                    <dxr:RibbonPageGroup Caption="主题与皮肤 (Themes)">
                        <!--  【升级】：使用自带实时预览的 Ribbon 主题画廊  -->
                        <dxr:RibbonGalleryBarItem x:Name="ThemeGallery" Content="切换皮肤 (Themes)">
                            <dxmvvm:Interaction.Behaviors>
                                <!--  这个魔法行为会自动扫描所有安装的主题，并为你画出分类好的图标！  -->
                                <dxr:RibbonGalleryItemThemeSelectorBehavior />
                            </dxmvvm:Interaction.Behaviors>
                        </dxr:RibbonGalleryBarItem>
                    </dxr:RibbonPageGroup>
                </dxr:RibbonPage>

                <!--  插件会在代码里动态挂载到这个 Category 后面  -->
            </dxr:RibbonDefaultPageCategory>
        </dxr:RibbonControl>


        <!--  2. 中间：高级停靠管理器  -->
        <dxd:DockLayoutManager
            x:Name="DockManager"
            Grid.Row="1"
            FloatingMode="Desktop">
            <dxd:LayoutGroup Orientation="Vertical">

                <!--  上半部分：插件工作区 (MDI)  -->
                <dxd:DocumentGroup
                    x:Name="MdiContainer"
                    ClosePageButtonShowMode="InActiveTabPageHeader"
                    DestroyOnClosingChildren="False"
                    ItemHeight="3*">

                    <!--  【修复】：自适应主题的欢迎大屏  -->
                    <dxd:DocumentPanel
                        AllowDrag="False"
                        AllowFloat="False"
                        Caption="欢迎使用 (Welcome)"
                        ShowCloseButton="False">
                        <!--  去掉 Background="#2D2D30"，让它跟随全局主题  -->
                        <Grid>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <dx:DXImage
                                    Width="150"
                                    Height="150"
                                    Margin="0,0,0,20"
                                    Source="{dx:DXImage 'SvgImages/Dashboards/Cards.svg'}" />

                                <!--  去掉 Foreground="White"，利用 Opacity 制造高级的灰色视觉差  -->
                                <TextBlock
                                    FontSize="48"
                                    FontWeight="Bold"
                                    Opacity="0.8"
                                    Text="NatsROS 工业控制大屏"
                                    TextAlignment="Center" />
                                <TextBlock
                                    Margin="0,10,0,30"
                                    FontSize="20"
                                    Foreground="#007ACC"
                                    Text="Enterprise Distributed Robotics Framework based on NATS"
                                    TextAlignment="Center" />

                                <!--  用自带主题引擎的 GroupBox 代替原来写死的黑底 Border  -->
                                <dxlc:LayoutGroup
                                    Width="600"
                                    Padding="15"
                                    Header="💡 快速开始指南"
                                    Orientation="Vertical"
                                    View="GroupBox">
                                    <!--  使用 Opacity="0.7" 代替 Foreground="DarkGray"，在黑白主题下都能完美显示  -->
                                    <TextBlock
                                        Margin="0,5"
                                        FontSize="14"
                                        Opacity="0.7"
                                        Text="1. 确保后台已启动 nats-server (推荐附加 -js 参数以启用高级流特性)。" />
                                    <TextBlock
                                        Margin="0,5"
                                        FontSize="14"
                                        Opacity="0.7"
                                        Text="2. 确保包含节点的 DLL 文件存放在 Plugins 目录下以便动态注入。" />
                                    <TextBlock
                                        Margin="0,5"
                                        FontSize="14"
                                        Opacity="0.7"
                                        Text="3. 点击上方 Ribbon 菜单栏中的插件按钮，即可开启对应的监控与调试工具。" />
                                    <TextBlock
                                        Margin="0,5"
                                        FontSize="14"
                                        Opacity="0.7"
                                        Text="4. 所有窗口均支持自由拖拽停靠，您可以按需拼装属于自己的指挥中心！" />
                                </dxlc:LayoutGroup>
                            </StackPanel>
                        </Grid>
                    </dxd:DocumentPanel>
                </dxd:DocumentGroup>

                <!--  下半部分：固定内置的全局日志面板  -->
                <dxd:LayoutPanel
                    AllowFloat="True"
                    Caption="全局遥测日志 (/rosout) [内置核心]"
                    ItemHeight="1*"
                    ShowCloseButton="False">
                    <!--  【修复】：去掉 Background="#1E1E1E" 和 Foreground="White"  -->
                    <!--  设置 Background="Transparent" 让它完全融合进父级面板的颜色中  -->
                    <RichTextBox
                        x:Name="RtbLogs"
                        Background="Transparent"
                        BorderThickness="0"
                        FontFamily="Consolas"
                        FontSize="13"
                        IsReadOnly="True"
                        VerticalScrollBarVisibility="Auto">
                        <FlowDocument x:Name="LogDocument" PagePadding="5" />
                    </RichTextBox>
                </dxd:LayoutPanel>

            </dxd:LayoutGroup>
        </dxd:DockLayoutManager>

        <!--  3. 底部：全局系统状态栏  -->
        <dxb:StatusBarControl Grid.Row="2">
            <dxb:BarStaticItem
                x:Name="StatusConnection"
                Content="准备连接 NATS..."
                Glyph="{dx:DXImage 'SvgImages/Icon Builder/Security_Warning.svg'}" />
            <dxb:BarStaticItem
                x:Name="StatusPluginCount"
                Alignment="Default"
                Content="加载了 0 个插件" />
        </dxb:StatusBarControl>

    </Grid>
</dx:ThemedWindow>
