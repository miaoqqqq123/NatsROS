<UserControl
    x:Class="NatsROS.Dashboard.Plugins.TopicRadar.TopicRadarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:dxprg="http://schemas.devexpress.com/winfx/2008/xaml/propertygrid"
    Background="Transparent">

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="350" />
        </Grid.ColumnDefinitions>

        <dxlc:LayoutGroup
            Grid.Column="0"
            Header="全网实时数据流探针"
            View="GroupBox">
            <dxg:GridControl
                x:Name="GridTopics"
                AutoGenerateColumns="None"
                SelectedItemChanged="GridTopics_SelectedItemChanged">
                <dxg:GridControl.View>
                    <dxg:TableView
                        AllowEditing="True"
                        EnableImmediatePosting="True"
                        NavigationStyle="Cell"
                        ShowGroupPanel="False" />
                </dxg:GridControl.View>

                <dxg:GridColumn
                    Width="40"
                    AllowEditing="True"
                    FieldName="IsMonitored"
                    Header="👀">
                    <dxg:GridColumn.EditSettings>
                        <dxe:CheckEditSettings />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn
                    Width="200"
                    AllowEditing="False"
                    FieldName="TopicName"
                    Header="话题名称" />

                <dxg:GridColumn
                    Width="250"
                    AllowEditing="False"
                    FieldName="MessageTypeName"
                    Header="类型 (Type)">
                    <!--  使用 CellStyle 来改变字体颜色和样式  -->
                    <dxg:GridColumn.CellStyle>
                        <Style TargetType="dxg:LightweightCellEditor">
                            <Setter Property="Foreground" Value="#007ACC" />
                        </Style>
                    </dxg:GridColumn.CellStyle>
                </dxg:GridColumn>

                <dxg:GridColumn
                    Width="70"
                    AllowEditing="False"
                    FieldName="Hz"
                    Header="频率(Hz)">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings DisplayFormat="F1" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn
                    Width="70"
                    AllowEditing="False"
                    FieldName="LastSize"
                    Header="大小(B)" />

                <dxg:GridColumn
                    Width="100"
                    AllowEditing="False"
                    FieldName="TotalMessages"
                    Header="总捕获量" />
            </dxg:GridControl>
        </dxlc:LayoutGroup>

        <GridSplitter
            Grid.Column="1"
            HorizontalAlignment="Stretch"
            Background="Transparent" />

        <dxlc:LayoutGroup
            Grid.Column="2"
            Header="实时报文解析 (Live Message Inspector)"
            View="GroupBox">
            <dxprg:PropertyGridControl
                x:Name="PropGridLive"
                ExpandCategoriesWhenSelectedObjectChanged="True"
                ReadOnly="True"
                ShowSearchBox="False" />
        </dxlc:LayoutGroup>
    </Grid>
</UserControl>
