<UserControl
    x:Class="NatsROS.Dashboard.Plugins.BagPlayer.BagPlayerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    Background="Transparent">

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  1. 录制面板 (Record)  -->
        <dxlc:LayoutGroup
            Grid.Row="0"
            Margin="0,0,0,10"
            Header="⏺ 数据录制引擎 (Bag Recorder)"
            View="GroupBox">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <dxlc:LayoutControl
                    Grid.Row="0"
                    Margin="0,0,0,5"
                    Padding="0">
                    <dxlc:LayoutGroup Orientation="Horizontal">
                        <!--  【新增】：预扫描按钮  -->
                        <dx:SimpleButton
                            x:Name="BtnRefreshTopics"
                            Width="130"
                            Height="30"
                            Margin="0,0,10,0"
                            Click="BtnRefreshTopics_Click"
                            Content="🔄 预扫描网络话题" />
                        <dx:SimpleButton
                            x:Name="BtnToggleRecord"
                            Width="140"
                            Height="30"
                            Background="#FFDDDD"
                            Click="BtnToggleRecord_Click"
                            Content="⏺ 开始录制 (Start)"
                            FontWeight="Bold"
                            Foreground="DarkRed" />
                        <dxlc:LayoutItem
                            Width="320"
                            Margin="15,0,0,0"
                            Label="保存路径:">
                            <dxe:TextEdit
                                x:Name="TxtBagSavePath"
                                IsReadOnly="True"
                                Text="C:\temp\natsros_record.bag" />
                        </dxlc:LayoutItem>
                        <Label
                            x:Name="LblRecordStats"
                            Margin="15,0,0,0"
                            VerticalAlignment="Center"
                            Content="已录制: 0 条报文 | 大小: 0 MB"
                            FontWeight="Bold"
                            Foreground="Gray" />
                    </dxlc:LayoutGroup>
                </dxlc:LayoutControl>

                <dxg:GridControl
                    x:Name="GridRecordTopics"
                    Grid.Row="1"
                    MaxHeight="250"
                    AutoGenerateColumns="None">
                    <dxg:GridControl.View>
                        <dxg:TableView
                            AllowEditing="True"
                            EnableImmediatePosting="True"
                            NavigationStyle="Cell"
                            ShowGroupPanel="False" />
                    </dxg:GridControl.View>
                    <dxg:GridColumn
                        Width="80"
                        AllowEditing="True"
                        FieldName="IsRecordEnabled"
                        Header="录制(Record)">
                        <dxg:GridColumn.EditSettings>
                            <dxe:CheckEditSettings />
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                    <dxg:GridColumn
                        Width="250"
                        AllowEditing="False"
                        FieldName="TopicName"
                        Header="网络中捕获的话题" />

                    <!--  【新增】：类型列  -->
                    <dxg:GridColumn
                        Width="*"
                        AllowEditing="False"
                        FieldName="TopicType"
                        Header="消息类型 (Type)">
                        <dxg:GridColumn.CellStyle>
                            <Style TargetType="dxg:LightweightCellEditor">
                                <Setter Property="Foreground" Value="#007ACC" />
                            </Style>
                        </dxg:GridColumn.CellStyle>
                    </dxg:GridColumn>

                    <dxg:GridColumn
                        Width="150"
                        AllowEditing="False"
                        FieldName="RecordedCount"
                        Header="已录制帧数" />
                </dxg:GridControl>
            </Grid>
        </dxlc:LayoutGroup>


        <!--  2. 回放面板 (Replay)  -->
        <dxlc:LayoutGroup
            Grid.Row="1"
            Margin="0,0,0,10"
            Header="▶️ 现场重播引擎 (Advanced Bag Player)"
            View="GroupBox">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="200" />
                </Grid.RowDefinitions>

                <dxlc:LayoutControl
                    Grid.Row="0"
                    Margin="0,0,0,10"
                    Padding="0">
                    <dxlc:LayoutGroup Orientation="Horizontal">
                        <dx:SimpleButton
                            x:Name="BtnLoadBag"
                            Width="150"
                            Height="30"
                            Click="BtnLoadBag_Click"
                            Content="📂 加载并解析 Bag" />
                        <dxlc:LayoutItem
                            Width="450"
                            Margin="10,0,0,0"
                            Label="文件:">
                            <dxe:TextEdit x:Name="TxtBagLoadPath" IsReadOnly="True" />
                        </dxlc:LayoutItem>
                        <dx:SimpleButton
                            x:Name="BtnPlayBag"
                            Width="120"
                            Margin="10,0,0,0"
                            Background="#DDFFDD"
                            Click="BtnPlayBag_Click"
                            Content="▶️ 播放 (Play)"
                            FontWeight="Bold"
                            Foreground="DarkGreen"
                            IsEnabled="False" />
                        <dx:SimpleButton
                            x:Name="BtnPauseBag"
                            Width="120"
                            Margin="5,0,0,0"
                            Click="BtnPauseBag_Click"
                            Content="⏸ 暂停"
                            IsEnabled="False" />
                        <dxlc:LayoutItem
                            Width="100"
                            Margin="10,0,0,0"
                            Label="倍速:">
                            <dxe:ComboBoxEdit
                                x:Name="CboPlaySpeed"
                                IsTextEditable="False"
                                SelectedIndex="1">
                                <dxe:ComboBoxEditItem Content="0.5x" />
                                <dxe:ComboBoxEditItem Content="1.0x" />
                                <dxe:ComboBoxEditItem Content="2.0x" />
                                <dxe:ComboBoxEditItem Content="5.0x" />
                                <dxe:ComboBoxEditItem Content="Max" />
                            </dxe:ComboBoxEdit>
                        </dxlc:LayoutItem>
                        <Label
                            x:Name="LblPlayTime"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Content="00:00.0 / 00:00.0"
                            FontWeight="Bold" />
                    </dxlc:LayoutGroup>
                </dxlc:LayoutControl>

                <dxe:TrackBarEdit
                    x:Name="SliderTimeline"
                    Grid.Row="1"
                    Margin="10,0,10,10"
                    EditValueChanged="SliderTimeline_EditValueChanged"
                    Maximum="100"
                    Minimum="0"
                    Value="0" />

                <dxg:GridControl
                    x:Name="GridBagTopics"
                    Grid.Row="2"
                    AutoGenerateColumns="None">
                    <dxg:GridControl.View>
                        <dxg:TableView
                            AllowEditing="True"
                            NavigationStyle="Row"
                            ShowGroupPanel="False" />
                    </dxg:GridControl.View>
                    <dxg:GridColumn
                        Width="60"
                        AllowEditing="True"
                        FieldName="IsPlayEnabled"
                        Header="允许回放">
                        <dxg:GridColumn.EditSettings>
                            <dxe:CheckEditSettings />
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                    <dxg:GridColumn
                        Width="*"
                        AllowEditing="False"
                        FieldName="TopicName"
                        Header="Bag 内包含的话题" />
                    <dxg:GridColumn
                        Width="*"
                        AllowEditing="False"
                        FieldName="TopicType"
                        Header="消息类型 (Type)">
                        <dxg:GridColumn.CellStyle>
                            <Style TargetType="dxg:LightweightCellEditor">
                                <Setter Property="Foreground" Value="#007ACC" />
                            </Style>
                        </dxg:GridColumn.CellStyle>
                    </dxg:GridColumn>
                    <dxg:GridColumn
                        Width="100"
                        AllowEditing="False"
                        FieldName="MessageCount"
                        Header="报文数量" />
                </dxg:GridControl>
            </Grid>
        </dxlc:LayoutGroup>

        <!--  3. 说明  -->
        <dxlc:LayoutGroup Grid.Row="2" View="Group">
            <TextBlock
                Margin="10"
                FontSize="14"
                Foreground="Gray"
                TextWrapping="Wrap">
                <Run FontWeight="Bold" Foreground="#007ACC">💡 NatsROS Bag 使用指南：</Run><LineBreak />
                1. 点击【开始录制】，系统会以纳秒级精度截获全网纯二进制流并落盘保存。<LineBreak />
                2. 勾选需要回放的特定话题（强烈建议过滤掉 RPC 相关的请求避免重放攻击）。<LineBreak />
                3. 点击【播放】，系统会严格按照时间轴将历史数据重新打入网络！</TextBlock>
        </dxlc:LayoutGroup>
    </Grid>
</UserControl>
