<UserControl
    x:Class="NatsROS.Dashboard.Plugins.PublisherCaller.PublisherCallerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:dxprg="http://schemas.devexpress.com/winfx/2008/xaml/propertygrid"
    Background="Transparent">

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ==========================================  -->
        <!--  上半区：消息发布器 (Message Publisher)  -->
        <!--  ==========================================  -->
        <dxlc:LayoutControl
            Grid.Row="0"
            Margin="0,0,0,10"
            Padding="0">
            <dxlc:LayoutGroup
                Header="1. 发送话题数据 (Publish Topic)"
                Orientation="Horizontal"
                View="Group">
                <dxlc:LayoutItem Width="200" Label="话题 (Topic):">
                    <dxe:TextEdit x:Name="TxtPubTopic" Text="test_chatter" />
                </dxlc:LayoutItem>
                <dxlc:LayoutItem Width="350" Label="类型 (Type):">
                    <dxe:ComboBoxEdit
                        x:Name="CboPubType"
                        AutoComplete="True"
                        DisplayMember="FullName"
                        ImmediatePopup="True"
                        SelectedIndexChanged="CboPubType_SelectedIndexChanged" />
                </dxlc:LayoutItem>
                <dxlc:LayoutItem Width="150" Label="频率(Hz):">
                    <dxe:SpinEdit
                        x:Name="SpinPubHz"
                        MaxValue="100"
                        MinValue="0.1"
                        Value="1" />
                </dxlc:LayoutItem>
                <dx:SimpleButton
                    x:Name="BtnPubOnce"
                    Width="80"
                    Margin="10,0,0,0"
                    Click="BtnPubOnce_Click"
                    Content="单次发送" />
                <dx:SimpleButton
                    x:Name="BtnPubStart"
                    Width="100"
                    Margin="5,0,0,0"
                    Click="BtnPubStart_Click"
                    Content="▶️ 循环发送" />
            </dxlc:LayoutGroup>
        </dxlc:LayoutControl>

        <dxlc:LayoutGroup
            Grid.Row="1"
            Margin="0,0,0,10"
            Header="消息载荷构造器 (Payload Editor)"
            View="GroupBox">
            <dxprg:PropertyGridControl
                x:Name="PropGridPublisher"
                ExpandCategoriesWhenSelectedObjectChanged="True"
                ShowSearchBox="True" />
        </dxlc:LayoutGroup>

        <!-- ========================================== -->
        <!-- 下半区：服务与动作调试器 (Service/Action Caller) -->
        <!-- ========================================== -->
        <dxlc:LayoutControl Grid.Row="2" Padding="0" Margin="0,0,0,10">
            <dxlc:LayoutGroup Orientation="Horizontal" View="Group" Header="2. 发起同步调用 (Call Service / Action)">
                <dxlc:LayoutItem Label="寻址路由 (Route):" Width="250">
                    <dxe:TextEdit x:Name="TxtSrvName" Text="agv.beep"/>
                </dxlc:LayoutItem>

                <!-- 【核心升级】：删掉 Res 框，拉长 Req 框，因为系统现在全自动推导响应类型！ -->
                <dxlc:LayoutItem Label="契约类型 (Req / Goal):" Width="450">
                    <dxe:ComboBoxEdit x:Name="CboSrvReqType" AutoComplete="True" ImmediatePopup="True" DisplayMember="FullName" SelectedIndexChanged="CboSrvReqType_SelectedIndexChanged"/>
                </dxlc:LayoutItem>

                <dxlc:LayoutItem Label="超时(秒):" Width="150">
                    <dxe:SpinEdit x:Name="SpinSrvTimeout" Value="0" MinValue="0" MaxValue="3600"/>
                </dxlc:LayoutItem>
                <dx:SimpleButton x:Name="BtnCallService" Content="🚀 发起调用" Click="BtnCallService_Click" Width="100" Margin="10,0,0,0"/>
                <dx:SimpleButton x:Name="BtnCancelAction" Content="🛑 强行打断" Click="BtnCancelAction_Click" Width="100" Margin="5,0,0,0" Background="#FFC62828" Foreground="White" FontWeight="Bold"/>
            </dxlc:LayoutGroup>
        </dxlc:LayoutControl>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <dxlc:LayoutGroup
                Grid.Column="0"
                Header="请求参数 (Req Payload)"
                View="GroupBox">
                <dxprg:PropertyGridControl x:Name="PropGridSrvReq" ExpandCategoriesWhenSelectedObjectChanged="True" />
            </dxlc:LayoutGroup>
            <GridSplitter
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                Background="Transparent" />
            <dxlc:LayoutGroup
                Grid.Column="2"
                Header="响应结果 (Res Result)"
                View="GroupBox">
                <dxprg:PropertyGridControl
                    x:Name="PropGridSrvRes"
                    ExpandCategoriesWhenSelectedObjectChanged="True"
                    ReadOnly="True" />
            </dxlc:LayoutGroup>
        </Grid>
    </Grid>
</UserControl>
