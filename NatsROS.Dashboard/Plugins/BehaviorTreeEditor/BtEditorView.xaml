<UserControl
    x:Class="NatsROS.Dashboard.Plugins.BehaviorTreeEditor.BtEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxdiag="http://schemas.devexpress.com/winfx/2008/xaml/diagram"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:dxprg="http://schemas.devexpress.com/winfx/2008/xaml/propertygrid"
    Background="Transparent"
    Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <DataTemplate x:Key="NodeCanvasTemplate">
            <!-- 节点外边框 (带有深色阴影和状态发光边框) -->
            <Border Width="180" MinHeight="60" Background="#2D2D30" CornerRadius="8" 
                    BorderBrush="{Binding StatusColor}" BorderThickness="3"
                    Margin="5">
                <!-- 给节点加一点阴影 -->
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.5" ShadowDepth="3" Color="Black"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <!-- 标题栏 -->
                        <RowDefinition Height="*"/>
                        <!-- 内容区 -->
                    </Grid.RowDefinitions>

                    <!-- 标题栏：带有不同类型的背景色 (Sequence/Selector/Action) -->
                    <Border Grid.Row="0" Background="{Binding HeaderColor}" CornerRadius="6,6,0,0">
                        <StackPanel Orientation="Horizontal" Margin="8,0">
                            <!-- 图标 -->
                            <TextBlock Text="{Binding Icon}" FontFamily="Segoe UI Emoji" FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                            <!-- 节点名称 -->
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="White" Margin="5,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="130"/>
                        </StackPanel>
                    </Border>

                    <!-- 内容区：显示参数摘要或运行状态 -->
                    <Border Grid.Row="1" Background="Transparent" Padding="8,5">
                        <StackPanel>
                            <!-- 比如：这里可以绑定底层类的具体参数 -->
                            <TextBlock Text="{Binding Subtitle}" FontSize="11" Foreground="DarkGray" TextWrapping="Wrap"/>
                            <!-- 状态文字 -->
                            <TextBlock Text="{Binding StatusText}" FontSize="12" FontWeight="Bold" Foreground="{Binding StatusColor}" HorizontalAlignment="Right" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>
    
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  顶部：保存与导出工具栏  -->
        <dxlc:LayoutControl
            Grid.Row="0"
            Margin="0,0,0,5"
            Padding="0">
            <dxlc:LayoutGroup Orientation="Horizontal" View="Group">
                <dx:SimpleButton
                    Width="130"
                    Height="30"
                    Click="BtnLoadXml_Click"
                    Content="导入 XML (Load)"
                    Glyph="{dx:DXImage 'SvgImages/Actions/Open.svg'}" />
                <dx:SimpleButton
                    Width="130"
                    Height="30"
                    Margin="10,0,0,0"
                    Click="BtnSaveXml_Click"
                    Content="导出 XML (Save)"
                    Glyph="{dx:DXImage 'SvgImages/Save/Save.svg'}" />
                <dx:SimpleButton
                    Width="180"
                    Height="30"
                    Margin="10,0,0,0"
                    Click="BtnAutoLayout_Click"
                    Content="✨ 自动排版 (Auto Layout)"
                    Glyph="{dx:DXImage 'SvgImages/DiagramIcons/Layout.svg'}" />
                <dx:SimpleButton
                    Width="200"
                    Height="30"
                    Margin="30,0,0,0"
                    Background="#DDFFDD"
                    Click="BtnDeploy_Click"
                    Content="🚀 动态下发至大脑 (Deploy to Brain)"
                    FontWeight="Bold"
                    Foreground="DarkGreen" />
            </dxlc:LayoutGroup>
        </dxlc:LayoutControl>

        <!--  下半部分：左中右三栏布局  -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="350" />
            </Grid.ColumnDefinitions>
            <!--  【工具箱（从这里开始）】  -->
            <dxdiag:DiagramToolboxControl
                x:Name="DiagramToolbox"
                Grid.Column="0"
                MaxWidth="250"
                DiagramControl="{Binding ElementName=DiagramCanvas}" />

            <!--  左中：DevExpress 强大的流程图编辑器 (自带工具箱)  -->
            <dxlc:LayoutGroup
                Grid.Column="1"
                Header="🎨 可视化编排画布 (Visual Canvas)"
                View="GroupBox">
                <!--  开启工具箱、网格线和属性同步  -->
                <dxdiag:DiagramControl
                    x:Name="DiagramCanvas"
                    CanvasSizeMode="Fill"
                    ConnectionChanged="DiagramCanvas_ConnectionChanged"
                    SelectedStencils="BasicShapes"
                    SelectionChanged="DiagramCanvas_SelectionChanged"
                    ShowGrid="True"
                    ShowRulers="True"
                    ToolboxVisibility="Closed" />
            </dxlc:LayoutGroup>

            <GridSplitter
                Grid.Column="2"
                HorizontalAlignment="Stretch"
                Background="Transparent" />

            <!--  右侧：选中节点的参数编辑器  -->
            <dxlc:LayoutGroup
                Grid.Column="3"
                Header="⚙️ 节点参数配置 (Properties)"
                View="GroupBox">
                <!--  它将完美渲染我们之前写的带有 [BtProp] 标签的属性！  -->
                <dxprg:PropertyGridControl
                    x:Name="PropGridNode"
                    ExpandCategoriesWhenSelectedObjectChanged="True"
                    ShowSearchBox="True" />
            </dxlc:LayoutGroup>
        </Grid>
    </Grid>
</UserControl>