<UserControl
    x:Class="NatsROS.Dashboard.Plugins.NodeManager.NodeManagerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:dxprg="http://schemas.devexpress.com/winfx/2008/xaml/propertygrid"
    Background="Transparent">

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="350" />
        </Grid.ColumnDefinitions>

        <!--  左侧：智能组件库 (恢复单点发射能力)  -->
        <dxlc:LayoutGroup
            Grid.Column="0"
            Header="🛒 智能组件库 (双击单点发射)"
            View="GroupBox">
            <dxg:GridControl
                x:Name="GridAvailableNodes"
                AutoGenerateColumns="None"
                MouseDoubleClick="GridAvailableNodes_MouseDoubleClick">
                <dxg:GridControl.View>
                    <dxg:TableView
                        AllowEditing="False"
                        NavigationStyle="Row"
                        ShowGroupPanel="True" />
                </dxg:GridControl.View>
                <dxg:GridColumn
                    FieldName="Category"
                    GroupIndex="0"
                    Header="分类" />
                <dxg:GridColumn
                    Width="*"
                    FieldName="FullDisplayName"
                    Header="组件名称" />
            </dxg:GridControl>
        </dxlc:LayoutGroup>

        <GridSplitter
            Grid.Column="1"
            HorizontalAlignment="Stretch"
            Background="Transparent" />

        <!--  中间：带生命周期管理的运行节点  -->
        <dxlc:LayoutGroup
            Grid.Column="2"
            Header="🟢 运行中的微服务节点 (Active Nodes)"
            View="GroupBox">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,5" Orientation="Horizontal">
                    <dx:SimpleButton
                        Width="80"
                        Height="28"
                        Click="BtnRefresh_Click"
                        Content="🔄 刷新" />
                    <dx:SimpleButton
                        Width="100"
                        Height="28"
                        Margin="10,0,0,0"
                        Background="#DDFFDD"
                        Click="BtnStateActive_Click"
                        Content="▶ 激活(Active)"
                        Foreground="DarkGreen" />
                    <dx:SimpleButton
                        Width="110"
                        Height="28"
                        Margin="5,0,0,0"
                        Background="#FFF9C4"
                        Click="BtnStateInactive_Click"
                        Content="⏸ 待机(Inactive)"
                        Foreground="DarkOrange" />
                    <dx:SimpleButton
                        Width="100"
                        Height="28"
                        Margin="10,0,0,0"
                        Click="BtnUnloadNode_Click"
                        Content="⏹️ 强行卸载"
                        Foreground="DarkRed" />
                </StackPanel>

                <dxg:GridControl
                    x:Name="GridNodes"
                    Grid.Row="1"
                    AutoGenerateColumns="None"
                    SelectedItemChanged="GridNodes_SelectedItemChanged">
                    <dxg:GridControl.View>
                        <dxg:TableView
                            AllowEditing="False"
                            NavigationStyle="Row"
                            ShowGroupPanel="False" />
                    </dxg:GridControl.View>
                    <dxg:GridColumn
                        Width="150"
                        FieldName="NodeName"
                        Header="实例名称" />
                    <!--  显示状态  -->
                    <dxg:GridColumn
                        Width="*"
                        FieldName="StateStr"
                        Header="生命周期状态">
                        <dxg:GridColumn.EditSettings>
                            <dxe:TextEditSettings />
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                </dxg:GridControl>
            </Grid>
        </dxlc:LayoutGroup>

        <GridSplitter
            Grid.Column="3"
            HorizontalAlignment="Stretch"
            Background="Transparent" />

        <!--  右侧：参数热更 (保持原样)  -->
        <dxlc:LayoutGroup
            x:Name="GrpNodeParams"
            Grid.Column="4"
            Header="⚙️ 节点参数热更"
            View="GroupBox">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <dxprg:PropertyGridControl
                    x:Name="PropGridParams"
                    ExpandCategoriesWhenSelectedObjectChanged="True"
                    ShowSearchBox="True" />
                <dx:SimpleButton
                    x:Name="BtnApplyParams"
                    Grid.Row="1"
                    Height="35"
                    Margin="0,10,0,0"
                    Click="BtnApplyParams_Click"
                    Content="🔥 下发热更新 (Apply)"
                    IsEnabled="False" />
            </Grid>
        </dxlc:LayoutGroup>
    </Grid>
</UserControl>