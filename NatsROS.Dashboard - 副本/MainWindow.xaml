<dx:ThemedWindow
    x:Class="NatsROS.Dashboard.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxdiag="clr-namespace:DevExpress.Xpf.Diagram;assembly=DevExpress.Xpf.Diagram.v23.2"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:dxprg="http://schemas.devexpress.com/winfx/2008/xaml/propertygrid"
    Title="NatsROS 动态节点管理器与雷达监控"
    Width="1200"
    Height="750"
    Closing="Window_Closing"
    Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  顶部：节点加载控制台  -->
        <dxlc:LayoutControl Grid.Row="0" Margin="5">
            <dxlc:LayoutGroup
                Header="🚀 母体动态注入引擎 (Dynamic Node Loader)"
                Orientation="Horizontal"
                View="GroupBox">
                <dxlc:LayoutItem Label="目标节点类 (Target Class):">
                    <dxe:ComboBoxEdit x:Name="CboAvailableNodes" AutoComplete="True" ImmediatePopup="True" 
                                      DisplayMember="DisplayName" NullText="请选择或搜索要注入的节点类..."/>
                </dxlc:LayoutItem>
                <dxlc:LayoutItem Label="运行节点名(Name):" Width="400">
                    <dxe:TextEdit x:Name="TxtNodeName" Text="sensor_1" />
                </dxlc:LayoutItem>
                <dx:SimpleButton
                    Width="120"
                    Margin="10,0,0,0"
                    Click="BtnLoadNode_Click"
                    Content="注入母体 (Load)" />
                <dx:SimpleButton
                    Width="90"
                    Margin="5,0,0,0"
                    Click="BtnRefresh_Click"
                    Content="刷新列表" />
            </dxlc:LayoutGroup>
        </dxlc:LayoutControl>

        <!--  下方主体：引入选项卡以容纳多种高级工具  -->
        <dx:DXTabControl Grid.Row="1" Margin="10,0,10,10">

            <!--  ==========================================  -->
            <!--  Tab 1: 节点管理器、参数热更与日志  -->
            <!--  ==========================================  -->
            <dx:DXTabItem Header="🖥️ 母体节点大盘 (Node Manager)">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="350" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  左侧：母体节点列表  -->
                    <dxlc:LayoutGroup
                        Grid.Column="0"
                        Header="运行中的微服务节点"
                        View="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <!--  【核心】：增加 SelectedItemChanged 事件，选中节点时触发查参数  -->
                            <dxg:GridControl
                                x:Name="GridNodes"
                                AutoGenerateColumns="None"
                                EnableSmartColumnsGeneration="False"
                                SelectedItemChanged="GridNodes_SelectedItemChanged">
                                <dxg:GridControl.View>
                                    <dxg:TableView
                                        AllowEditing="False"
                                        NavigationStyle="Row"
                                        ShowGroupPanel="False" />
                                </dxg:GridControl.View>
                                <dxg:GridColumn
                                    Width="*"
                                    FieldName="NodeName"
                                    Header="节点实例名称" />
                            </dxg:GridControl>
                            <dx:SimpleButton
                                Grid.Row="1"
                                Height="30"
                                Margin="0,10,0,0"
                                Click="BtnUnloadNode_Click"
                                Content="⏹️ 卸载选中节点" />
                        </Grid>
                    </dxlc:LayoutGroup>

                    <GridSplitter
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        Background="Transparent" />

                    <!--  中间：节点专属参数配置器 (Parameter Reconfigure)  -->
                    <dxlc:LayoutGroup
                        x:Name="GrpNodeParams"
                        Grid.Column="2"
                        Header="节点参数热更新 (Parameters)"
                        View="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  属性网格：用来动态展示未知数量的 Key-Value  -->
                            <dxprg:PropertyGridControl
                                x:Name="PropGridParams"
                                ExpandCategoriesWhenSelectedObjectChanged="True"
                                ShowSearchBox="True" />

                            <!--  提交按钮  -->
                            <dx:SimpleButton
                                x:Name="BtnApplyParams"
                                Grid.Row="1"
                                Height="30"
                                Margin="0,10,0,0"
                                Click="BtnApplyParams_Click"
                                Content="💾 应用参数更改 (Apply)"
                                Glyph="{dx:DXImage 'SvgImages/Save/Save.svg'}"
                                IsEnabled="False" />
                        </Grid>
                    </dxlc:LayoutGroup>

                    <GridSplitter
                        Grid.Column="3"
                        HorizontalAlignment="Stretch"
                        Background="Transparent" />

                    <!--  右侧：全局日志  -->
                    <dxlc:LayoutGroup
                        Grid.Column="4"
                        Header="全局遥测日志 (/rosout)"
                        View="GroupBox">
                        <RichTextBox
                            x:Name="RtbLogs"
                            Background="#1E1E1E"
                            FontFamily="Consolas"
                            FontSize="13"
                            Foreground="White"
                            IsReadOnly="True"
                            VerticalScrollBarVisibility="Auto">
                            <FlowDocument x:Name="LogDocument" PagePadding="5" />
                        </RichTextBox>
                    </dxlc:LayoutGroup>
                </Grid>
            </dx:DXTabItem>


            <!--  ==========================================  -->
            <!--  Tab 2: 全网话题监控雷达 (Topic Monitor)  -->
            <!--  ==========================================  -->
            <dx:DXTabItem Header="📡 话题监控雷达 (Topic Monitor)">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="350" />
                    </Grid.ColumnDefinitions>

                    <dxlc:LayoutGroup
                        Grid.Column="0"
                        Header="全网实时数据流探针"
                        View="GroupBox">
                        <dxg:GridControl
                            x:Name="GridTopics"
                            AutoGenerateColumns="None"
                            SelectedItemChanged="GridTopics_SelectedItemChanged">
                            <dxg:GridControl.View>
                                <dxg:TableView
                                    AllowEditing="True"
                                    EnableImmediatePosting="True"
                                    NavigationStyle="Cell"
                                    ShowGroupPanel="False" />
                            </dxg:GridControl.View>

                            <dxg:GridColumn
                                Width="40"
                                AllowEditing="True"
                                FieldName="IsMonitored"
                                Header="👀">
                                <dxg:GridColumn.EditSettings>
                                    <dxe:CheckEditSettings />
                                </dxg:GridColumn.EditSettings>
                            </dxg:GridColumn>
                            <dxg:GridColumn
                                Width="200"
                                AllowEditing="False"
                                FieldName="TopicName"
                                Header="话题名称" />

                            <!--  【新增】Type 列  -->
                            <dxg:GridColumn
                                Width="250"
                                AllowEditing="False"
                                FieldName="MessageTypeName"
                                Header="类型 (Type)" />

                            <dxg:GridColumn
                                Width="70"
                                AllowEditing="False"
                                FieldName="Hz"
                                Header="频率(Hz)">
                                <dxg:GridColumn.EditSettings>
                                    <dxe:TextEditSettings DisplayFormat="F1" />
                                </dxg:GridColumn.EditSettings>
                            </dxg:GridColumn>
                            <dxg:GridColumn
                                Width="70"
                                AllowEditing="False"
                                FieldName="LastSize"
                                Header="大小(B)" />

                            <dxg:GridColumn
                                Width="100"
                                AllowEditing="False"
                                FieldName="TotalMessages"
                                Header="总捕获量" />
                        </dxg:GridControl>
                    </dxlc:LayoutGroup>

                    <GridSplitter
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        Background="Transparent" />
                    <!--  【新增】：右侧的动态属性网格 (完全对标 RQT)  -->
                    <dxlc:LayoutGroup
                        Grid.Column="2"
                        Header="实时报文解析 (Live Message Inspector)"
                        View="GroupBox">
                        <!--  这个神器会自动根据传入的 Object 反射生成树状编辑/查看界面  -->
                        <dxprg:PropertyGridControl
                            x:Name="PropGridLive"
                            ExpandCategoriesWhenSelectedObjectChanged="True"
                            ReadOnly="True"
                            ShowSearchBox="False" />
                    </dxlc:LayoutGroup>
                </Grid>
            </dx:DXTabItem>


            <!--  ==========================================  -->
            <!--  Tab 3: 消息发布器与类型浏览器 (Message Publisher)  -->
            <!--  ==========================================  -->
            <dx:DXTabItem Header="📤 消息发布器 (Message Publisher)">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  顶部控制条  -->
                    <dxlc:LayoutControl
                        Grid.Row="0"
                        Margin="0,0,0,10"
                        Padding="0">
                        <dxlc:LayoutGroup Orientation="Horizontal" View="Group">
                            <dxlc:LayoutItem Width="200" Label="话题 (Topic):">
                                <dxe:TextEdit x:Name="TxtPubTopic" Text="test_chatter" />
                            </dxlc:LayoutItem>

                            <!--  支持搜索的类型下拉框  -->
                            <dxlc:LayoutItem Width="350" Label="类型 (Type):">
                                <dxe:ComboBoxEdit
                                    x:Name="CboPubType"
                                    AutoComplete="True"
                                    DisplayMember="FullName"
                                    ImmediatePopup="True"
                                    SelectedIndexChanged="CboPubType_SelectedIndexChanged" />
                            </dxlc:LayoutItem>

                            <dxlc:LayoutItem Width="100" Label="频率 (Hz):">
                                <dxe:SpinEdit
                                    x:Name="SpinPubHz"
                                    MaxValue="100"
                                    MinValue="0.1"
                                    Value="1" />
                            </dxlc:LayoutItem>

                            <dx:SimpleButton
                                x:Name="BtnPubOnce"
                                Width="80"
                                Margin="10,0,0,0"
                                Click="BtnPubOnce_Click"
                                Content="单次发送" />
                            <dx:SimpleButton
                                x:Name="BtnPubStart"
                                Width="100"
                                Margin="5,0,0,0"
                                Click="BtnPubStart_Click"
                                Content="▶️ 循环发送" />
                        </dxlc:LayoutGroup>
                    </dxlc:LayoutControl>

                    <!--  下方：消息构造器 / 类型浏览器  -->
                    <dxlc:LayoutGroup
                        Grid.Row="1"
                        Header="消息载荷构造器 (Payload Editor Type Browser)"
                        View="GroupBox">
                        <!--  这个网格既能展示类型结构，又能编辑数据  -->
                        <dxprg:PropertyGridControl
                            x:Name="PropGridPublisher"
                            ExpandCategoriesWhenSelectedObjectChanged="True"
                            ShowSearchBox="True" />
                    </dxlc:LayoutGroup>
                </Grid>
            </dx:DXTabItem>

            <!--  ==========================================  -->
            <!--  Tab 4: 服务调试器 (Service Caller)  -->
            <!--  ==========================================  -->
            <dx:DXTabItem Header="🛎️ 服务调试器 (Service Caller)">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  顶部：RPC 服务配置区  -->
                    <dxlc:LayoutControl
                        Grid.Row="0"
                        Margin="0,0,0,10"
                        Padding="0">
                        <dxlc:LayoutGroup Orientation="Horizontal" View="Group">
                            <dxlc:LayoutItem Width="250" Label="服务名称 (Service Name):">
                                <dxe:TextEdit x:Name="TxtSrvName" Text="add_two_ints" />
                            </dxlc:LayoutItem>

                            <dxlc:LayoutItem Width="280" Label="请求类型 (Req Type):">
                                <dxe:ComboBoxEdit
                                    x:Name="CboSrvReqType"
                                    AutoComplete="True"
                                    DisplayMember="FullName"
                                    ImmediatePopup="True"
                                    SelectedIndexChanged="CboSrvReqType_SelectedIndexChanged" />
                            </dxlc:LayoutItem>

                            <dxlc:LayoutItem Width="280" Label="响应类型 (Res Type):">
                                <dxe:ComboBoxEdit
                                    x:Name="CboSrvResType"
                                    AutoComplete="True"
                                    DisplayMember="FullName"
                                    ImmediatePopup="True" />
                            </dxlc:LayoutItem>

                            <dxlc:LayoutItem Width="90" Label="超时(秒):">
                                <dxe:SpinEdit
                                    x:Name="SpinSrvTimeout"
                                    MaxValue="60"
                                    MinValue="1"
                                    Value="5" />
                            </dxlc:LayoutItem>

                            <dx:SimpleButton
                                x:Name="BtnCallService"
                                Width="120"
                                Margin="10,0,0,0"
                                Click="BtnCallService_Click"
                                Content="🚀 发起 RPC 调用" />
                        </dxlc:LayoutGroup>
                    </dxlc:LayoutControl>

                    <!--  下方：请求参数编辑区 & 响应结果查看区  -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--  左侧：请求参数构造器  -->
                        <dxlc:LayoutGroup
                            Grid.Column="0"
                            Header="1. 构造请求参数 (Request Payload)"
                            View="GroupBox">
                            <dxprg:PropertyGridControl x:Name="PropGridSrvReq" ExpandCategoriesWhenSelectedObjectChanged="True" />
                        </dxlc:LayoutGroup>

                        <GridSplitter
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            Background="Transparent" />

                        <!--  右侧：RPC 响应结果查看器  -->
                        <dxlc:LayoutGroup
                            Grid.Column="2"
                            Header="2. 接收响应结果 (Response Result)"
                            View="GroupBox">
                            <dxprg:PropertyGridControl
                                x:Name="PropGridSrvRes"
                                ExpandCategoriesWhenSelectedObjectChanged="True"
                                ReadOnly="True" />
                        </dxlc:LayoutGroup>
                    </Grid>
                </Grid>
            </dx:DXTabItem>


            <!--  ==========================================  -->
            <!--  Tab 5: 全网拓扑计算图 (Node Graph)  -->
            <!--  ==========================================  -->
            <dx:DXTabItem Header="🕸️ 节点计算拓扑图 (Node Graph)">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  第一行：操作按钮  -->
                    <dxlc:LayoutControl
                        Grid.Row="0"
                        Margin="0,0,0,5"
                        Padding="0">
                        <dxlc:LayoutGroup Orientation="Horizontal" View="Group">
                            <dx:SimpleButton
                                Width="180"
                                Height="30"
                                Click="BtnGenerateGraph_Click"
                                Content="🔍 扫描并生成拓扑图"
                                Glyph="{dx:DXImage 'SvgImages/DiagramIcons/GenerateData.svg'}" />
                            <dx:SimpleButton
                                Width="200"
                                Height="30"
                                Margin="10,0,0,0"
                                Click="BtnAutoLayout_Click"
                                Content="✨ 重新自动排版 (Sugiyama)"
                                Glyph="{dx:DXImage 'SvgImages/DiagramIcons/Layout.svg'}" />
                            <Label
                                Margin="15,0,0,0"
                                VerticalAlignment="Center"
                                Content="图例：方形=Node | 椭圆=Topic | 菱形=Service"
                                Foreground="Gray" />
                        </dxlc:LayoutGroup>
                    </dxlc:LayoutControl>

                    <dxlc:LayoutControl
                        Grid.Row="1"
                        Margin="0,0,0,10"
                        Padding="0">
                        <dxlc:LayoutGroup
                            Header="节点与话题过滤器 (Filters)"
                            Orientation="Horizontal"
                            View="GroupBox">
                            <dxe:CheckEdit
                                x:Name="ChkHideRosout"
                                Margin="0,0,15,0"
                                Content="隐藏系统日志 (Hide /rosout)"
                                IsChecked="True" />
                            <dxe:CheckEdit
                                x:Name="ChkHideParams"
                                Margin="0,0,15,0"
                                Content="隐藏参数服务 (Hide Params)"
                                IsChecked="True" />
                            <dxe:CheckEdit
                                x:Name="ChkHideServices"
                                Margin="0,0,15,0"
                                Content="隐藏所有服务 (Hide Services)"
                                IsChecked="False" />
                            <dxe:CheckEdit
                                x:Name="ChkHideDiscovery"
                                Content="隐藏发现协议 (Hide Discovery)"
                                IsChecked="True" />
                        </dxlc:LayoutGroup>
                    </dxlc:LayoutControl>

                    <!--  第三行：画布  -->
                    <dxlc:LayoutGroup
                        Grid.Row="2"
                        Header="分布式架构自省视图 (Introspection View)"
                        View="GroupBox">
                        <!--  配置为支持平移缩放、默认使用直线连接 (对标 RQT)  -->
                        <dxdiag:DiagramControl
                            x:Name="DiagramGraph"
                            ShowGrid="False"
                            ShowPageBreaks="False"
                            ShowRulers="False" />
                    </dxlc:LayoutGroup>
                </Grid>
            </dx:DXTabItem>

            <!--  ==========================================  -->
            <!--  Tab 6: 数据黑匣子 (NatsROS Bag)  -->
            <!--  ==========================================  -->
            <dx:DXTabItem Header="📼 数据黑匣子 (NatsROS Bag)">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  1. 录制面板 (Record)  -->
                    <dxlc:LayoutGroup
                        Grid.Row="0"
                        Margin="0,0,0,10"
                        Header="⏺ 数据录制引擎 (Bag Recorder)"
                        View="GroupBox">
                        <dxlc:LayoutControl Padding="0">
                            <dxlc:LayoutGroup Orientation="Horizontal">
                                <dx:SimpleButton
                                    x:Name="BtnToggleRecord"
                                    Width="180"
                                    Height="30"
                                    Background="#FFDDDD"
                                    Click="BtnToggleRecord_Click"
                                    Content="⏺ 开始录制 (Start Record)"
                                    FontWeight="Bold"
                                    Foreground="DarkRed" />
                                <dxlc:LayoutItem
                                    Width="350"
                                    Margin="15,0,0,0"
                                    Label="保存路径:">
                                    <dxe:TextEdit
                                        x:Name="TxtBagSavePath"
                                        IsReadOnly="True"
                                        Text="C:\temp\natsros_record.bag" />
                                </dxlc:LayoutItem>
                                <Label
                                    x:Name="LblRecordStats"
                                    Margin="15,0,0,0"
                                    VerticalAlignment="Center"
                                    Content="已录制: 0 条报文 | 文件大小: 0 MB"
                                    FontWeight="Bold"
                                    Foreground="Gray" />
                            </dxlc:LayoutGroup>
                        </dxlc:LayoutControl>
                    </dxlc:LayoutGroup>

                    <!--  2. 现场重播引擎 (Bag Player)  -->
                    <dxlc:LayoutGroup
                        Grid.Row="1"
                        Margin="0,0,0,10"
                        Header="▶️ 现场重播引擎 (Advanced Bag Player)"
                        View="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="200" />
                                <!--  给话题列表留空间  -->
                            </Grid.RowDefinitions>

                            <!--  第一行：控制按钮  -->
                            <dxlc:LayoutControl
                                Grid.Row="0"
                                Margin="0,0,0,10"
                                Padding="0">
                                <dxlc:LayoutGroup Orientation="Horizontal">
                                    <dx:SimpleButton
                                        x:Name="BtnLoadBag"
                                        Width="150"
                                        Height="30"
                                        Click="BtnLoadBag_Click"
                                        Content="📂 加载并解析 Bag" />
                                    <dxlc:LayoutItem
                                        Width="250"
                                        Margin="10,0,0,0"
                                        Label="文件:">
                                        <dxe:TextEdit x:Name="TxtBagLoadPath" IsReadOnly="True" />
                                    </dxlc:LayoutItem>
                                    <dx:SimpleButton
                                        x:Name="BtnPlayBag"
                                        Width="90"
                                        Margin="10,0,0,0"
                                        Click="BtnPlayBag_Click"
                                        Content="▶️ 播放 (Play)"
                                        IsEnabled="False" />
                                    <dx:SimpleButton
                                        x:Name="BtnPauseBag"
                                        Width="70"
                                        Margin="5,0,0,0"
                                        Click="BtnPauseBag_Click"
                                        Content="⏸ 暂停"
                                        IsEnabled="False" />
                                    <dxlc:LayoutItem
                                        Width="100"
                                        Margin="10,0,0,0"
                                        Label="倍速:">
                                        <dxe:ComboBoxEdit
                                            x:Name="CboPlaySpeed"
                                            IsTextEditable="False"
                                            SelectedIndex="1">
                                            <dxe:ComboBoxEditItem Content="0.5x" />
                                            <dxe:ComboBoxEditItem Content="1.0x" />
                                            <dxe:ComboBoxEditItem Content="2.0x" />
                                            <dxe:ComboBoxEditItem Content="Max" />
                                        </dxe:ComboBoxEdit>
                                    </dxlc:LayoutItem>
                                    <Label
                                        x:Name="LblPlayTime"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        Content="00:00.0 / 00:00.0"
                                        FontWeight="Bold" />
                                    <Label
                                        x:Name="LblPlayStats"
                                        Margin="15,0,0,0"
                                        VerticalAlignment="Center"
                                        Content="进度: 等待加载"
                                        FontWeight="Bold"
                                        Foreground="Gray" />
                                </dxlc:LayoutGroup>
                            </dxlc:LayoutControl>

                            <!--  第二行：时间轴进度条 (Timeline)  -->
                            <dxe:TrackBarEdit
                                x:Name="SliderTimeline"
                                Grid.Row="1"
                                Margin="10,0,10,10"
                                EditValueChanged="SliderTimeline_EditValueChanged"
                                Maximum="100"
                                Minimum="0"
                                Value="0" />

                            <!--  第三行：Bag 内部话题列表 (对标 RQT 左侧)  -->
                            <dxg:GridControl
                                x:Name="GridBagTopics"
                                Grid.Row="2"
                                AutoGenerateColumns="None">
                                <dxg:GridControl.View>
                                    <dxg:TableView
                                        AllowEditing="True"
                                        NavigationStyle="Cell"
                                        ShowGroupPanel="False" />
                                </dxg:GridControl.View>
                                <dxg:GridColumn
                                    Width="50"
                                    AllowEditing="True"
                                    FieldName="IsPlayEnabled"
                                    Header="回放">
                                    <dxg:GridColumn.EditSettings>
                                        <dxe:CheckEditSettings />
                                    </dxg:GridColumn.EditSettings>
                                </dxg:GridColumn>
                                <dxg:GridColumn
                                    Width="*"
                                    AllowEditing="False"
                                    FieldName="TopicName"
                                    Header="Bag 内包含的话题" />
                                <dxg:GridColumn
                                    Width="100"
                                    AllowEditing="False"
                                    FieldName="MessageCount"
                                    Header="报文数量" />
                            </dxg:GridControl>
                        </Grid>
                    </dxlc:LayoutGroup>

                    <!--  3. 说明与提示  -->
                    <dxlc:LayoutGroup Grid.Row="2" View="Group">
                        <TextBlock
                            Margin="10"
                            FontSize="14"
                            Foreground="Gray"
                            TextWrapping="Wrap">
                            <Run FontWeight="Bold" Foreground="LightSkyBlue">💡 NatsROS Bag 使用指南：</Run><LineBreak />
                            1. 点击【开始录制】，系统会以纳秒级精度，将整个 NATS 网络里飞驰的纯二进制数据流直接落盘保存。<LineBreak />
                            2. 发生异常后，将生成的 .bag 文件加载至【重播引擎】。<LineBreak />
                            3. 点击【播放】，系统会严格按照当时的真实时间间隔（或加速），将历史数据重新打入网络。<LineBreak />
                            4. 此时，你的雷达、拓扑图、甚至真实的硬件订阅节点，都会如同坐上时光机一样，完美复现当时的场景！</TextBlock>
