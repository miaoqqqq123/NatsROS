<dx:ThemedWindow
    x:Class="NatsROS.Hmi.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    Title="NatsROS 智能测试工位 - 生产模式"
    Width="1024"
    Height="800"
    Closing="Window_Closing"
    Loaded="Window_Loaded"
    WindowStartupLocation="CenterScreen">

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  上半区：控制面板与巨型结果指示灯  -->
        <dxlc:LayoutControl Grid.Row="0" Margin="10">
            <dxlc:LayoutGroup Orientation="Horizontal">

                <!--  左侧操作区  -->
                <dxlc:LayoutGroup
                    Width="400"
                    Header="🧑‍🔧 操作台 (Operator Panel)"
                    Orientation="Vertical"
                    View="GroupBox">
                    <TextBlock
                        Margin="0,10,0,5"
                        FontSize="16"
                        Foreground="LightGray"
                        Text="产品条码 (Barcode):" />
                    <dxe:TextEdit
                        x:Name="TxtBarcode"
                        Height="40"
                        FontSize="24"
                        SelectAllOnGotFocus="True"
                        Text="SN-20260331-0001" />

                    <dx:SimpleButton
                        x:Name="BtnStart"
                        Height="80"
                        Margin="0,20,0,10"
                        Background="#FF2E7D32"
                        Click="BtnStart_Click"
                        Content="▶ 开始测试 (START)"
                        FontSize="28"
                        FontWeight="Bold"
                        Foreground="White" />

                    <dx:SimpleButton
                        x:Name="BtnEStop"
                        Height="60"
                        Background="#FFC62828"
                        Click="BtnEStop_Click"
                        Content="🛑 紧急停止 (E-STOP)"
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="White" />
                </dxlc:LayoutGroup>

                <!--  右侧结果区  -->
                <dxlc:LayoutGroup
                    Margin="10,0,0,0"
                    Header="📊 最终判定 (Final Verdict)"
                    View="GroupBox">
                    <Border
                        x:Name="BorderResult"
                        Margin="10"
                        Background="#FF37474F"
                        CornerRadius="10">
                        <TextBlock
                            x:Name="TxtResult"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="96"
                            FontWeight="Black"
                            Foreground="White"
                            Text="WAITING" />
                    </Border>
                </dxlc:LayoutGroup>

                <dxlc:LayoutGroup
                    Margin="10,10,0,0"
                    Header="⚙️ 物理硬件直连监控 (Real-time Hardware Telemetry)"
                    View="GroupBox">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,5"
                            Foreground="LightGray"
                            Text="X 轴当前物理绝对坐标:" />
                        <!--  这个进度条将直接受底层轴卡节点驱动，丝滑移动！  -->
                        <dxe:ProgressBarEdit
                            x:Name="PbAxisPos"
                            Height="30"
                            ContentDisplayMode="Value"
                            FontSize="16"
                            FontWeight="Bold"
                            Maximum="200"
                            Minimum="0" />
                    </StackPanel>
                </dxlc:LayoutGroup>

            </dxlc:LayoutGroup>
        </dxlc:LayoutControl>

        <!--  下半区：测试流水账实时展示  -->
        <dxlc:LayoutControl
            Grid.Row="1"
            Margin="10,0,10,10"
            Padding="0">
            <dxlc:LayoutGroup Header="📋 测试工序实时明细 (Test Step Details)" View="GroupBox">
                <dxg:GridControl x:Name="GridSteps" AutoGenerateColumns="None">
                    <dxg:GridControl.View>
                        <dxg:TableView
                            AllowEditing="False"
                            FontSize="16"
                            NavigationStyle="Row"
                            RowMinHeight="40"
                            ShowGroupPanel="False" />
                    </dxg:GridControl.View>
                    <dxg:GridColumn
                        Width="*"
                        FieldName="StepName"
                        Header="测试项名称" />
                    <dxg:GridColumn
                        Width="200"
                        FieldName="Status"
                        Header="状态 (Status)">
                        <dxg:GridColumn.EditSettings>
                            <dxe:TextEditSettings />
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                    <dxg:GridColumn
                        Width="150"
                        FieldName="Progress"
                        Header="进度">
                        <dxg:GridColumn.EditSettings>
                            <dxe:ProgressBarEditSettings
                                ContentDisplayMode="Value"
                                Maximum="100"
                                Minimum="0" />
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                </dxg:GridControl>
            </dxlc:LayoutGroup>
        </dxlc:LayoutControl>
    </Grid>
</dx:ThemedWindow>